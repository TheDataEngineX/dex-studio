# DEX Studio — Environment Variables
# Copy to .env and fill in values — never commit .env
# The app auto-loads .env from the current directory on startup.

# ── Required ──────────────────────────────────────────────────────────────────

# Session signing key (random hex string, >= 32 bytes).
# Generate one: python -c "import secrets; print(secrets.token_hex(32))"
DEX_STUDIO_SESSION_SECRET=

# ── Postgres (multi-pod mode) ─────────────────────────────────────────────────

# When set, enables PostgreSQL backend for scheduler leadership, pipeline locks,
# auth/preferences persistence. When absent, uses local SQLite (single-pod).
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dex_studio

# ── Auth ──────────────────────────────────────────────────────────────────────

# Fixed password — when set, disables the /setup UI flow. If absent, a random
# password is generated on first boot (visible in startup logs).
# DEX_STUDIO_PASSPHRASE=

# ── Engine ────────────────────────────────────────────────────────────────────

# Path to a dex.yaml project config. If absent, scans ~/.dex-studio/projects/
# and bundled examples/.
# DEX_CONFIG_PATH=

# ── HTTPS / Security ──────────────────────────────────────────────────────────

# Set to 1, true, or yes to enable HTTPS-only session cookies + HSTS header.
# DEX_HTTPS=false

# Number of trusted reverse-proxy hops for client IP extraction (rate limiting).
# 0 = disable X-Forwarded-For trust (default).
# DEX_TRUSTED_PROXIES=0
