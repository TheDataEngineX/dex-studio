# DEX Studio Environment Variables
# Copy to .env and fill in values — never commit .env

# DEX engine connection
DEX_STUDIO_DEX_URL=http://localhost:17000

# Studio server
DEX_STUDIO_PORT=7860
DEX_STUDIO_TITLE=DEX Studio

# Window mode
DEX_STUDIO_NATIVE=true            # true = native window (pywebview), false = browser tab

# Theme
DEX_STUDIO_THEME=dark             # dark | light
